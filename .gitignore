# Virtual Environment
.venv/
env/
venv/
__pycache__/
*.pyc

# Live progress + status (regenerable runtime files)
results/current_status*.json
results/live_progress*.md
results/periodic_log.txt
results/tune_log.txt
results/startup_error.txt

# Run logs
results/*/run.log
results/*/run.log.err

# Exclude obsolete result directories (only 6:4, 80:20, 7:1:2 OC20 kept)
results/cross_*/
results/intra_bipulseformer/
results/intra_pure_bipulseformer_712/
results/intra_pure_bipulseformer_712_random/
results/intra_pure_bipulseformer_subj_exclusive/
results/intra_ubfc_bipulseformer_712/
results/intra_ubfc_physformer/
results/intra_ubfc_spiking/
results/pretrain_*/
results/preproc_check/

# Per-epoch waveforms (large, regenerable from checkpoints)
results/*/waveforms/

# Auxiliary analysis files (one-off diagnostics)
results/per_clip_evaluation.json
results/per_clip_eval_log.txt
results/per_clip_test_best.txt
results/pure_oc20_analysis.txt
results/valid_vs_test_oc20.txt
results/plots/spiking_biformer/
results/plots/bipulseformer/per_subject_intra_PURE_session_split_epoch7.csv

# Big files
*.avi
*.log
D:/
logs/

# Paper sources (too large / external)
paper.pdf
paper_abs.html
paper_v4.html
paper_text.txt
paper_chunk_*.txt

# Temporary files
tmp_*.py
tmp_*.ipynb

# Scheduled task lock
.claude/scheduled_tasks.lock

# PNG default-exclude (we'll force-add specific plots)
*.png
!results/plots/bipulseformer/scatter_*.png
!results/plots/bipulseformer/bland_altman_*.png

# Checkpoint default-exclude — only keep best epoch per training
results/*/checkpoints/*.pt
!results/intra_ubfc_bipulseformer/checkpoints/UBFC-rPPG_to_UBFC-rPPG_epoch8.pt
!results/intra_pure_bipulseformer/checkpoints/PURE_to_PURE_epoch7.pt
!results/intra_pure_bipulseformer_80_20/checkpoints/PURE_to_PURE_epoch9.pt
!results/intra_pure_bipulseformer_712_oc20/checkpoints/PURE_epoch11.pt
!results/intra_ubfc_bipulseformer_712_oc20/checkpoints/UBFC-rPPG_epoch10.pt
